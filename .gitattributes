# Normalize line endings across the team.
#
# Store all text files with LF in the repository and check them out with
# LF, regardless of each contributor's local core.autocrlf setting. This
# stops the "LF will be converted to CRLF" churn on Windows and keeps
# diffs clean across Windows/macOS/Linux.
* text=auto eol=lf

# Shell scripts must stay LF; Windows batch files must stay CRLF.
*.sh   text eol=lf
*.bat  text eol=crlf
*.cmd  text eol=crlf

# Binary assets — never apply line-ending conversion.
*.png  binary
*.jpg  binary
*.jpeg binary
*.webp binary
*.gif  binary
*.ico  binary
*.pdf  binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.eot   binary
